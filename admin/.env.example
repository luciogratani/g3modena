# Copia questo file in `.env` (o `.env.local`) nella cartella admin:
#   cp .env.example .env
# Vite NON legge `.env.example`; senza `.env` le variabili VITE_* sono vuote in runtime.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

VITE_SUPABASE_CMS_TABLE=cms_sections
VITE_TENANT_SCHEMA=public
VITE_SUPABASE_MEDIA_BUCKET=site-media

# E5 baseline: l'admin richiede sessione Supabase Auth (role=authenticated).
# Con queste variabili mancanti, la UI mostra schermata "configurazione non pronta".

# URL pubblico del sito web (usato come base URL nel builder UTM campagne).
# Se non impostato, la pagina Campagne mostra "https://g3modena.com" come default editabile.
VITE_PUBLIC_SITE_ORIGIN=https://g3modena.com
